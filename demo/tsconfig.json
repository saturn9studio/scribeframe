{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "types": ["vite/client"],
    "baseUrl": ".",
    "paths": {
      "@saturn9/scribeframe": ["../src/index.ts"],
      "@saturn9/scribeframe/styles.css": ["../src/styles.css"]
    }
  },
  "include": ["src/**/*"]
}
